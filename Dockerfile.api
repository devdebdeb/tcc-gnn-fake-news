FROM python:3.11-slim

WORKDIR /app

# Dependências de sistema necessárias para compilação de pacotes C
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ \
    && rm -rf /var/lib/apt/lists/*

# ── Torch CPU (muito menor que a versão CUDA, ~1.2GB vs ~2.5GB) ──────────────
RUN pip install --no-cache-dir \
    torch==2.5.1 \
    --index-url https://download.pytorch.org/whl/cpu

# ── PyTorch Geometric ─────────────────────────────────────────────────────────
RUN pip install --no-cache-dir torch-geometric==2.6.1

# ── Demais dependências da API ────────────────────────────────────────────────
COPY requirements.api.txt .
RUN pip install --no-cache-dir -r requirements.api.txt

# ── Pré-download do modelo BERT (evita cold-start lento no primeiro uso) ──────
RUN python -c "\
from sentence_transformers import SentenceTransformer; \
SentenceTransformer('paraphrase-multilingual-mpnet-base-v2')"

# ── Código da aplicação ───────────────────────────────────────────────────────
# API
COPY frontend/api/ ./frontend/api/

# Módulos do projeto (coleta e embeddings) — sintaxe JSON para lidar com espaço no nome
COPY ["Blue Sky/src/", "./Blue Sky/src/"]

# Modelos treinados (.pth)
COPY mesclagem/pesos_gcn.pth          ./mesclagem/pesos_gcn.pth
COPY mesclagem/pesos_bs_ctrl.pth      ./mesclagem/pesos_bs_ctrl.pth
COPY mesclagem/pesos_bs_cetico.pth    ./mesclagem/pesos_bs_cetico.pth
COPY mesclagem/pesos_bs_ex_cetico.pth ./mesclagem/pesos_bs_ex_cetico.pth

WORKDIR /app/frontend/api

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
